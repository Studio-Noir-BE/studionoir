{% set baseUrl = alias('@web') ~ '/' %}
{% set notchColor = '#000000' %}

{#
   Studio Noir — static site data (Figma design).
   The CMS fields stay static for now: nav + socials live here so _pageHeader /
   _pageFooter and the page templates can share them. `assetBase` points at the
   committed static export (web/dist-site/) so the design's images and the
   sibling .html pages resolve while the rest of the site is wired into Craft.
   Parent-template vars are in scope for child blocks + includes.
#}
{% set assetBase = '/dist-site/' %}
{% set snNav = [
    { label: 'diensten',         url: 'diensten.html',  key: 'diensten'  },
    { label: 'over Studio Noir', url: 'over.html',       key: 'over'      },
    { label: 'inzichten',        url: 'inzichten.html',  key: 'inzichten' },
    { label: 'contact',          url: 'contact.html',    key: 'contact'   }
] %}
{% set snSocials = [
    { label: 'LinkedIn',  url: 'https://www.linkedin.com/' },
    { label: 'Instagram', url: 'https://www.instagram.com/' },
    { label: 'Facebook',  url: 'https://www.facebook.com/' }
] %}

<!doctype html>
<html lang="{{ craft.app.language }}" prefix="og: http://ogp.me/ns# fb: http://ogp.me/ns/fb#">
	<head>
		{%- minify -%}
		<meta charset="utf-8"/>
		<meta content="IE=edge" http-equiv="X-UA-Compatible">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		{# <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1"> #}
		<meta name="apple-mobile-web-app-capable" content="yes" />

		<meta name="apple-mobile-web-app-status-bar-style" content="{{ notchColor }}">
		<meta name="msapplication-navbutton-color" content="{{ notchColor }}">

		<meta name="format-detection" content="telephone=no">

		{# Favicons #}
		{{ craft.vite.inline("@webroot/dist/assets/favicons/webapp.html") }}

		{% include "_partials/cookies/_scripts" %}
		
		{%- endminify -%}		

		{%- minify -%}
		{# Site fonts #}
		{% include "_inlinecss/_site_fonts.twig" ignore missing %}
		{# Figma design fonts: Space Grotesk (display) + Onest (body) #}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Onest:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		{%- endminify -%}

		{%- minify -%}
		{# Inline JS #}
			<script type="text/javascript">
        		var baseUrl = "{{ baseUrl }}";
			</script>
		{# </head> JS #}
		{% block _head_js %}{% endblock %}

		{# Inlince css #}

		{# Prevent FOUC — body hidden until JS sets .is-ready on <body> #}
		{# CSS animation fallback: always visible after 0.8s even if JS fails #}
		<style>
			body { transition: opacity 0.8s ease; }
			body:not(.is-ready) {
				opacity: 0;
				animation: page-reveal 0s 0.8s forwards;
			}
			@keyframes page-reveal { to { opacity: 1; } }
		</style>

		{# Failsafe: never leave scroll-reveal sections hidden if JS fails. #}
		<noscript>
			<style>
				body { opacity: 1 !important; }
				[data-reveal] { opacity: 1 !important; transform: none !important; }
			</style>
		</noscript>


		{# Child templates can inject <link rel="preload"> for the LCP image here #}
		{% block preload %}{% endblock %}

		{% include "_partials/_css.twig" %}

		{# Load critical css when not in dev mode #}
		{% if getenv('CRAFT_ENVIRONMENT') != "dev" %}
			{{ craft.vite.includeCriticalCssTags() }}
		{% endif %}

		{# Load in our main app.js (this includes our app.css) #}
		{{ craft.vite.script('src/js/app.js', true) }}
	</head>

	{# HTML Body #}
	<body {% if bodyClass is defined %} class="{{ bodyClass }}" {% endif %}>

		{# Global glow blob — multi-layer, follows mouse, visible only on white #}
		<div id="sn-blob" aria-hidden="true">
			<div class="sn-blob-layer sn-blob-l1"></div>
			<div class="sn-blob-layer sn-blob-l2"></div>
			<div class="sn-blob-layer sn-blob-l3"></div>
		</div>

		{% block body %}{% endblock %}

		{# Page naviation #}
		{% include "_partials/_pageNavigation" %}	
		
		{# Scripts #}
		{% include "_partials/_scripts.twig" %}

		{# Fixed bottom-right UI: page-specific slot (e.g. availability pill).
		   Raised above the Crisp launcher so it never overlaps the chat bubble. #}
		<div id="sn-fixed-ui" style="position:fixed;bottom:5.5rem;right:1.5rem;z-index:200;display:flex;flex-direction:column;align-items:flex-end;gap:0.75rem;">
			{% block fixed_ui %}{% endblock %}
		</div>

		{# Inline JS #}
		{% block _inline_js %}{% endblock %}

		{%- endminify -%}

		{# Crisp Chat — standard embed (chatbox styled in the Crisp dashboard) #}
		<script type="text/javascript">
			window.$crisp=[];window.CRISP_WEBSITE_ID="37df2615-0b0e-4e66-9bf3-8e41c9d3b028";
			(function(){var d=document,s=d.createElement("script");s.src="https://client.crisp.chat/l.js";s.async=1;d.getElementsByTagName("head")[0].appendChild(s);})();
		</script>
	</body>
</html>