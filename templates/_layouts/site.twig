{# Extends #}
{% extends '_layouts/base' %}

{% if bodyClass is not defined %}
    {% set bodyClass = entry is defined ? "#{entry.section.handle|capitalize}Page" : craft.app.request.segments|first %}
{% endif %}

{# Template #}
{% block body %}

    {% include '_partials/_pageHeader.twig' %}

    <main class="Main">
      	{% block main %}{% endblock %}
    </main>

    {% include '_partials/_pageFooter.twig' %}

    {# 12 col design grid #}
    {% if getenv('CRAFT_ENVIRONMENT') == 'dev' and getenv('DESIGN_GRID') %}   
        {% include "_partials/_blocks/_design-grid.twig" %}
    {% endif %}

{% endblock %}