{% extends '_layouts/site' %}

{# Inzicht detail (channel `inzichten` entry). Editable: title, intro, image, Inhoud. #}
{% set headerTheme = 'light' %}
{% set heroImg = entry.fieldImage.one() ?? null %}

{% block main %}

    {# Hero #}
    <section class="relative flex min-h-[56vh] items-end overflow-hidden bg-secondary">
        {% if heroImg %}
            <img src="{{ heroImg.url }}" alt="{{ heroImg.alt ?: entry.title }}"
                 class="absolute inset-0 h-full w-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/45 to-black/20"></div>
        {% else %}
            <div class="pointer-events-none absolute -left-20 top-10 h-[28rem] w-[28rem] glow-lime opacity-20"></div>
        {% endif %}
        <div class="shell-wide relative z-10 w-full pb-12 pt-40 lg:pb-16">
            <p class="eyebrow mb-4 text-primary">Inzicht</p>
            <h1 class="h-section text-white text-balance">{{ entry.title }}</h1>
        </div>
    </section>

    <article class="shell max-w-3xl space-y-6 py-16 lg:py-24">
        {% if entry.fieldIntro|striptags|trim is not empty %}
            <div class="sn-richtext text-xl leading-relaxed text-secondary" data-reveal>{{ entry.fieldIntro }}</div>
        {% endif %}

        {% set blocks = entry.fieldContent.all() ?? [] %}
        {% if blocks|length %}
            {% for block in blocks %}
                {% include "_content/blocks/#{block.type.handle}" ignore missing with { contentIndex: loop.index } %}
            {% endfor %}
        {% endif %}

        <div class="pt-8" data-reveal>
            <a href="{{ siteUrl }}inzichten" class="arrow-link text-secondary hover:text-primary">
                <span>←</span> Alle inzichten
            </a>
        </div>
    </article>

    {% include 'figma/_partials/cta-banner.twig' %}
    {% include 'figma/_partials/contact-card.twig' %}

{% endblock %}
