{% extends '_layouts/site' %}

{#
   Inzichten overzicht (single `inzichtenIndex`). Lists entries from the
   `inzichten` channel; falls back to static placeholder cards while empty.
   Editable: title, intro.
#}
{% set headerTheme = 'dark' %}
{% set posts = craft.entries().section('inzichten').all() %}

{% block main %}

    {# Hero (no image — glow on white) #}
    <section class="relative flex min-h-[52vh] items-end overflow-hidden bg-background">
        <div class="pointer-events-none absolute -left-20 top-10 h-[28rem] w-[28rem] glow-lime opacity-70"></div>
        <div class="pointer-events-none absolute left-1/4 top-1/3 h-[22rem] w-[22rem] glow-lime opacity-50"></div>
        <div class="shell-wide relative z-10 w-full pb-12 pt-40 lg:pb-16">
            <p class="eyebrow mb-4 text-secondary">Blog</p>
            <h1 class="h-hero text-secondary text-balance">{{ entry.title|default('Inzichten') }}</h1>
            {% if entry.fieldIntro|striptags|trim is not empty %}
                <div class="sn-richtext mt-5 max-w-xl text-lg text-muted">{{ entry.fieldIntro }}</div>
            {% endif %}
        </div>
    </section>

    <section class="shell pb-8 pt-4 lg:pt-8">
        <div class="grid grid-cols-1 gap-7 sm:grid-cols-2 lg:grid-cols-3">
            {% if posts|length %}
                {% for post in posts %}
                    {% set img = post.fieldImage.one() ?? null %}
                    <a href="{{ post.url }}" class="group flex flex-col overflow-hidden rounded-3xl border border-secondary/10 bg-white transition-transform duration-300 hover:-translate-y-1.5" data-reveal>
                        <div class="relative aspect-[4/3] overflow-hidden bg-tertiary">
                            {% if img %}
                                <img src="{{ img.url }}" alt="{{ img.alt ?: post.title }}"
                                     class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105">
                            {% endif %}
                        </div>
                        <div class="flex flex-1 flex-col p-6">
                            <h2 class="font-display text-xl font-bold leading-snug text-secondary">{{ post.title }}</h2>
                            <p class="mt-3 text-[15px] leading-relaxed text-muted">{{ post.fieldIntro|striptags|slice(0, 140) }}</p>
                            <span class="arrow-link mt-auto pt-6 text-secondary group-hover:text-primary">
                                Lees meer <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
                            </span>
                        </div>
                    </a>
                {% endfor %}
            {% else %}
                {# Placeholder while no posts are published yet #}
                {% for post in [
                    { title: 'Waarom een website op maat?', cat: 'Maatwerk', img: 'img/figma/inzicht-1.jpg', excerpt: 'Geen sjablonen, maar een uniek ontwerp dat perfect aansluit bij jouw merk en doelen.' },
                    { title: 'Wat is Craft CMS en waarom kiezen wij ervoor?', cat: 'Craft CMS', img: 'img/figma/inzicht-2.jpg', excerpt: 'Een krachtig, veilig en flexibel systeem dat is gemaakt voor maatwerk projecten.' },
                    { title: 'SEO én GEO: gevonden worden in Google én ChatGPT', cat: 'SEO & GEO', img: 'img/figma/inzicht-3.jpg', excerpt: 'Zichtbaar zijn in klassieke zoekmachines én in AI-tools zoals ChatGPT en Gemini.' }
                ] %}
                    <div class="group flex flex-col overflow-hidden rounded-3xl border border-secondary/10 bg-white" data-reveal>
                        <div class="relative aspect-[4/3] overflow-hidden">
                            <img src="{{ assetBase }}{{ post.img }}" alt="{{ post.title }}" class="h-full w-full object-cover">
                            <span class="absolute left-4 top-4 rounded-full bg-primary px-3 py-1 text-xs font-semibold text-secondary">{{ post.cat }}</span>
                        </div>
                        <div class="flex flex-1 flex-col p-6">
                            <h2 class="font-display text-xl font-bold leading-snug text-secondary">{{ post.title }}</h2>
                            <p class="mt-3 text-[15px] leading-relaxed text-muted">{{ post.excerpt }}</p>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </section>

    {% include 'figma/_partials/services-cta.twig' with {
        heading: 'Interesse in één van onze diensten?',
        sub: 'Of heeft u een andere vraag?'
    } %}

    {% include 'figma/_partials/faq.twig' %}
    {% include 'figma/_partials/cta-banner.twig' %}
    {% include 'figma/_partials/contact-card.twig' %}

{% endblock %}
