<script>
    // Define dataLayer and the gtag function.
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}

    // Default GTM denied
    gtag('consent', 'default', {
        'ad_storage': 'denied',
        'analytics_storage': 'denied'
    });
</script>

{% set trackingScripts = {
    'gtag': 'analytics',
    'googleTagManager': 'analytics',
    'facebookPixel': 'analytics',
    'linkedInInsight': 'analytics',
    'hubSpot': 'analytics',
    'pinterestTag': 'analytics',
    'fathom': 'analytics',
    'matomo': 'analytics',
    'plausible': 'analytics',
    'googleAnalytics': 'analytics'
 } %}

{% for key, value in trackingScripts %}
    {% set scriptTag = seomatic.script.get(key) %}
    
    {% if scriptTag|length %}
        {% do scriptTag.tagAttrs({
            "type": "text/plain",
            "data-category": value,
        }) %}
    {% endif %}

{% endfor %}

{# Grand GTM #}
<script type="text/plain" data-category="analytics">
    gtag('consent', 'update', {
        'analytics_storage': 'granted'
    });
</script>

{# Denied GTM #}
<script type="text/plain" data-category="!analytics">
    gtag('consent', 'update', {
        'analytics_storage': 'denied'
    });
</script>