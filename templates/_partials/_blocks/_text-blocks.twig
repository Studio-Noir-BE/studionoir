{% set textBlocks = textBlocks ?? null %}

{% if textBlocks == null %}
    {% set textBlocks = entry.textBlocks.all() ?? null %}
{% endif %}

{% if textBlocks %}
    <section class="MainGrid u-block">
        {% for textBlock in textBlocks %}     
            {% set fieldTitle = textBlock.fieldTitle %}
            {% set fieldText = textBlock.fieldText %}
            {% set fieldLink = textBlock.fieldLink %}

            <div class="flex flex-col col-span-full gap-8 items-start sm:col-start-2 sm:col-span-10 u-block--extraSmall {% if loop.first %}!mt-0{% endif %} {% if loop.index >= textBlocks|length %}!mb-0{% endif %}">
                {% if fieldTitle %}
                    <h3>{{ fieldTitle }}</h3>
                {% endif %}
                
                {% if fieldText %}
                    <div class="RichText">{{ fieldText }}</div>
                {% endif %}

                {% if fieldLink %}
                    {% include "_macros/button/button" with {
                        element: fieldLink,            
                        style: 'primary'
                    } %}
                {% endif %}
            </div>
        {% endfor %}
    </section>
{% endif %}