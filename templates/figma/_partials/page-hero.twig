{#
   Inner-page hero.
   Params: title, image (bg url, optional), theme ('light'|'dark' text),
           kicker (optional eyebrow), price (optional badge).
#}
{% set hasImage = image is defined and image %}
{% set textCls = (theme|default('light')) == 'light' ? 'text-white' : 'text-secondary' %}

<section class="relative flex min-h-[62vh] items-end overflow-hidden {{ hasImage ? 'bg-secondary' : 'bg-background' }}">
    {% if hasImage %}
        <img src="{{ assetBase }}{{ image }}" alt="" class="absolute inset-0 h-full w-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/45 to-black/20"></div>
    {% else %}
        <div class="pointer-events-none absolute -left-20 top-10 h-[28rem] w-[28rem] glow-lime opacity-70"></div>
        <div class="pointer-events-none absolute left-1/4 top-1/3 h-[22rem] w-[22rem] glow-lime opacity-50"></div>
    {% endif %}

    <div class="shell-wide relative z-10 w-full pb-12 pt-40 lg:pb-16">
        <div class="flex flex-wrap items-end justify-between gap-6">
            <div>
                {% if kicker is defined and kicker %}
                    <p class="eyebrow mb-4 {{ (theme|default('light')) == 'light' ? 'text-primary' : 'text-secondary' }}">{{ kicker }}</p>
                {% endif %}
                <h1 class="h-hero {{ textCls }} text-balance">{{ title|raw }}</h1>
            </div>
            {% if price is defined and price %}
                <span class="font-display text-2xl font-medium {{ textCls }} sm:text-3xl">{{ price }}</span>
            {% endif %}
        </div>
    </div>
</section>
