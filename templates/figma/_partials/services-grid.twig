{# Services overview — four dark cards. #}
<section id="diensten" class="shell py-16 lg:py-24">
    <div class="mb-10 lg:mb-14" data-reveal>
        <p class="eyebrow text-secondary">Wat we doen</p>
        <h2 class="h-section mt-3 text-secondary">{{ servicesTitle|default('Onze diensten') }}</h2>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-4">
        {% for s in site.services %}
            <a href="{{ assetBase }}{{ s.url }}"
               class="group flex flex-col rounded-3xl bg-secondary p-7 text-white transition-transform duration-300 hover:-translate-y-1.5"
               data-reveal>
                <div class="mb-4 flex items-start justify-between gap-3">
                    <h3 class="font-display text-2xl font-medium leading-tight">{{ s.title }}</h3>
                    {% if s.badge %}
                        <span class="shrink-0 rounded-full bg-primary px-3 py-1 text-xs font-semibold text-secondary">{{ s.badge }}</span>
                    {% endif %}
                </div>
                <p class="text-[15px] leading-relaxed text-white/65">{{ s.desc }}</p>
                <div class="mt-auto flex items-center justify-between pt-8">
                    <span class="arrow-link text-primary">
                        Meer info
                        <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
                    </span>
                    {% if s.price %}
                        <span class="font-display text-sm font-medium text-primary">{{ s.price }}</span>
                    {% endif %}
                </div>
            </a>
        {% endfor %}
    </div>
</section>
