{#
   Two-tone contact card: lime info column (left) + dark form column (right).
   Used at the bottom of most pages and as the main block of the contact page.
#}
<section id="contact" class="shell-wide py-12 lg:py-20" data-reveal>
    <div class="grid overflow-hidden rounded-[32px] lg:grid-cols-[0.85fr_1.15fr]">

        {# Lime info column #}
        <div class="flex flex-col justify-between gap-10 bg-primary p-8 sm:p-10 lg:p-12">
            <div class="h-16 w-max sm:h-20">
                {% include 'figma/_partials/logo.twig' %}
            </div>
            <div class="space-y-6">
                <a href="mailto:hello@studionoir.be"
                   class="block font-display text-2xl font-bold leading-tight text-secondary transition-opacity hover:opacity-70 sm:text-3xl">
                    hello@studionoir.be
                </a>
                <p class="font-display text-2xl font-bold leading-tight text-secondary sm:text-3xl">
                    Gelegen in Brugge
                </p>
                <div class="flex flex-wrap gap-x-6 gap-y-2 pt-2 font-display font-medium text-secondary">
                    {% for s in site.socials %}
                        <a href="{{ s.url }}" target="_blank" rel="noopener" class="transition-opacity hover:opacity-60">{{ s.label }}</a>
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Dark form column #}
        <div class="bg-secondary p-8 sm:p-10 lg:p-12">
            <h2 class="h-section mb-8 text-white">Neem contact op</h2>
            {% include 'figma/_partials/contact-form.twig' with { submitLabel: submitLabel|default('Verstuur bericht') } %}
        </div>
    </div>
</section>
