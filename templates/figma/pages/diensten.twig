{% extends 'figma/_layout.twig' %}

{% block content %}

    {% include 'figma/_partials/page-hero.twig' with {
        title: 'Onze diensten',
        image: 'img/figma/hero-diensten.jpg',
        kicker: 'Wat we doen',
        theme: 'light'
    } %}

    {# Intro #}
    <section class="shell py-14 lg:py-20">
        <p class="max-w-3xl text-xl leading-relaxed text-secondary text-balance" data-reveal>
            Van een compacte infosite tot een volledig maatwerk platform — we bouwen elke website
            snel, veilig en met oog voor detail. Hieronder vind je wat we doen en wat je mag verwachten.
        </p>
    </section>

    {# Detailed service blocks #}
    <section class="shell space-y-6 pb-8">
        {% for s in services_detail %}
            <article class="grid gap-6 rounded-[28px] border border-secondary/10 bg-white p-7 sm:p-10 lg:grid-cols-[auto_1fr] lg:items-start lg:gap-10"
                     data-reveal>
                <span class="font-display text-4xl font-medium text-secondary lg:text-5xl">{{ '%02d'|format(loop.index) }}</span>
                <div class="max-w-2xl">
                    <div class="flex flex-wrap items-center gap-4">
                        <h2 class="h-card text-secondary">{{ s.title }}</h2>
                        {% if s.price %}
                            <span class="rounded-full bg-primary px-4 py-1.5 font-display text-sm font-semibold text-secondary">{{ s.price }}</span>
                        {% endif %}
                    </div>
                    <p class="mt-4 whitespace-pre-line text-[17px] leading-relaxed text-muted">{{ s.desc }}</p>
                    {% if s.note %}
                        <p class="mt-3 text-sm italic text-muted/80">{{ s.note }}</p>
                    {% endif %}
                </div>
            </article>
        {% endfor %}
    </section>

    {# Mockup showcase #}
    <section class="shell py-12 lg:py-16" data-reveal>
        <div class="overflow-hidden rounded-[32px] bg-secondary p-6 sm:p-10">
            <img src="{{ assetBase }}img/figma/diensten-mockup.png" alt="Voorbeeld van een maatwerk website"
                 class="mx-auto w-full max-w-4xl rounded-2xl">
        </div>
    </section>

    {% include 'figma/_partials/faq.twig' %}
    {% include 'figma/_partials/cta-banner.twig' %}
    {% include 'figma/_partials/contact-card.twig' %}

{% endblock %}
