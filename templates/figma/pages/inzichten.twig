{% extends 'figma/_layout.twig' %}

{% set insights = [
    { title: 'Waarom een website op maat?', cat: 'Maatwerk', img: 'img/figma/inzicht-1.jpg', excerpt: 'Geen sjablonen, maar een uniek ontwerp dat perfect aansluit bij jouw merk en doelen.' },
    { title: 'Wat is Craft CMS en waarom kiezen wij ervoor?', cat: 'Craft CMS', img: 'img/figma/inzicht-2.jpg', excerpt: 'Een krachtig, veilig en flexibel systeem dat is gemaakt voor maatwerk projecten.' },
    { title: 'SEO én GEO: gevonden worden in Google én ChatGPT', cat: 'SEO & GEO', img: 'img/figma/inzicht-3.jpg', excerpt: 'Zichtbaar zijn in klassieke zoekmachines én in AI-tools zoals ChatGPT en Gemini.' },
    { title: 'Infosite of maatwerk: wat past bij jou?', cat: 'Advies', img: 'img/figma/inzicht-4.jpg', excerpt: 'Razendsnel online met een compacte infosite, of volledig op maat? We helpen je kiezen.' },
    { title: 'Hosting & onderhoud: zorgeloos online blijven', cat: 'Hosting', img: 'img/figma/inzicht-5.jpg', excerpt: 'Snelle, veilige hosting met SSL en maandelijks onderhoud — zonder kopzorgen.' },
    { title: 'Snelheid en veiligheid als basis van elke website', cat: 'Performance', img: 'img/figma/inzicht-6.jpg', excerpt: 'Geen overbodige code of plugins. Enkel wat jouw website écht nodig heeft.' }
] %}

{% block content %}

    {% include 'figma/_partials/page-hero.twig' with {
        title: 'Inzichten',
        kicker: 'Blog',
        theme: 'dark'
    } %}

    <section class="shell pb-8 pt-4 lg:pt-8">
        <div class="grid grid-cols-1 gap-7 sm:grid-cols-2 lg:grid-cols-3">
            {% for post in insights %}
                <a href="{{ assetBase }}inzichten-detail.html" class="group flex flex-col overflow-hidden rounded-3xl border border-secondary/10 bg-white transition-transform duration-300 hover:-translate-y-1.5" data-reveal>
                    <div class="relative aspect-[4/3] overflow-hidden">
                        <img src="{{ assetBase }}{{ post.img }}" alt="{{ post.title }}"
                             class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105">
                        <span class="absolute left-4 top-4 rounded-full bg-primary px-3 py-1 text-xs font-semibold text-secondary">{{ post.cat }}</span>
                    </div>
                    <div class="flex flex-1 flex-col p-6">
                        <h2 class="font-display text-xl font-bold leading-snug text-secondary">{{ post.title }}</h2>
                        <p class="mt-3 text-[15px] leading-relaxed text-muted">{{ post.excerpt }}</p>
                        <span class="arrow-link mt-auto pt-6 text-secondary group-hover:text-primary">
                            Lees meer <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
                        </span>
                    </div>
                </a>
            {% endfor %}
        </div>

        {# Pagination (static preview) #}
        <nav class="mt-12 flex items-center justify-center gap-2" aria-label="Paginering">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-secondary font-display text-sm font-medium text-white">1</span>
            {% for n in [2,3] %}
                <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full border border-secondary/15 font-display text-sm font-medium text-secondary transition-colors hover:bg-secondary hover:text-white">{{ n }}</a>
            {% endfor %}
            <span class="px-1 text-muted">…</span>
            <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full border border-secondary/15 font-display text-sm font-medium text-secondary transition-colors hover:bg-secondary hover:text-white">5</a>
        </nav>
    </section>

    {% include 'figma/_partials/services-cta.twig' with {
        heading: 'Interesse in één van onze diensten?',
        sub: 'Of heeft u een andere vraag?'
    } %}

    {% include 'figma/_partials/faq.twig' %}
    {% include 'figma/_partials/cta-banner.twig' %}
    {% include 'figma/_partials/contact-card.twig' %}

{% endblock %}
