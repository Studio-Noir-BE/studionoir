{#
   Studio Noir — base layout for the public website.
   Pure Twig (no Craft-specific tags) so it can be rendered statically for the
   GitHub Pages preview AND dropped into the Craft project later. Asset URLs are
   injected from the Vite manifest via the `assets` variable.
#}
<!doctype html>
<html lang="nl" class="scroll-smooth">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title is defined ? title ~ ' — Studio Noir' : 'Studio Noir — Websites met karakter' }}</title>
    <meta name="description" content="{{ description|default('Studio Noir bouwt websites met karakter. Maatwerk websites en compacte infosites, gebouwd in Craft CMS. Gelegen in Brugge.') }}">

    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ title is defined ? title ~ ' — Studio Noir' : 'Studio Noir — Websites met karakter' }}">
    <meta property="og:description" content="{{ description|default('Websites met karakter, gebouwd in Brugge.') }}">
    <meta name="theme-color" content="#202020">

    <link rel="icon" type="image/svg+xml" href="{{ assetBase }}img/favicon.svg">

    {# Fonts: Space Grotesk (display) + Onest (body). Inter is bundled in the CSS. #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Onest:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    {% for href in assets.css %}
        <link rel="stylesheet" href="{{ assetBase }}{{ href }}">
    {% endfor %}

    <style>
        /* Prevent FOUC — fade body in once JS marks it ready */
        body { transition: opacity .5s ease; }
        body:not(.is-ready) { opacity: 0; animation: snReveal 0s .8s forwards; }
        @keyframes snReveal { to { opacity: 1; } }
    </style>

    {# Failsafe: if JS is disabled or the main bundle fails to load, never leave
       scroll-reveal sections hidden. #}
    <noscript>
        <style>
            body { opacity: 1 !important; }
            [data-reveal] { opacity: 1 !important; transform: none !important; }
        </style>
    </noscript>
    <script>
        window.addEventListener('load', function () {
            setTimeout(function () {
                if (!window.__snReady) {
                    document.body.classList.add('is-ready');
                    document.querySelectorAll('[data-reveal]').forEach(function (el) {
                        el.classList.add('is-visible');
                    });
                }
            }, 2000);
        });
    </script>
</head>
<body class="min-h-screen bg-background text-secondary {{ bodyClass|default('') }}">

    {# Global glow blob — follows mouse, snaps to fixed positions via ScrollTrigger #}
    <div id="sn-blob" aria-hidden="true"></div>

    {% include 'figma/_partials/header.twig' %}

    <main id="main">
        {% block content %}{% endblock %}
    </main>

    {% include 'figma/_partials/footer.twig' %}

    {# Fixed bottom-right UI: page-specific slot (e.g. availability pill) + Crisp chat #}
    <div id="sn-fixed-ui" style="position:fixed;bottom:1.5rem;right:1.5rem;z-index:200;display:flex;flex-direction:column;align-items:flex-end;gap:0.75rem;">
        {% block fixed_ui %}{% endblock %}
        <button type="button" id="sn-chat-btn" class="sn-chat-btn" aria-label="Chat openen">
            <img src="{{ assetBase }}img/figma/avatar.jpg" alt="">
        </button>
    </div>

    {% for src in assets.js %}
        <script type="module" src="{{ assetBase }}{{ src }}"></script>
    {% endfor %}

    {# Crisp Chat #}
    <script type="text/javascript">
        window.$crisp=[];window.CRISP_WEBSITE_ID="37df2615-0b0e-4e66-9bf3-8e41c9d3b028";
        (function(){var d=document,s=d.createElement("script");s.src="https://client.crisp.chat/l.js";s.async=1;d.getElementsByTagName("head")[0].appendChild(s);})();
        document.getElementById("sn-chat-btn").addEventListener("click",function(){
            if(window.$crisp){window.$crisp.push(["do","chat:open"]);}
        });
    </script>
</body>
</html>
